{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @lofi/web build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "rewrites": [{ "source": "/((?!art/|assets/|manifest.webmanifest).*)", "destination": "/index.html" }]
}
