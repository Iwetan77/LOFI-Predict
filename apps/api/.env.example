# --- LOFI PREDICT relay/auth API ---
# Copy to .env and fill in. NEVER commit the real .env.

PORT=8787
NODE_ENV=development

# Where the game runs (used for OAuth redirects back to the app).
WEB_URL=http://localhost:5174

# Session cookie encryption — any random 32+ char string.
SESSION_SECRET=

# Google OAuth (Web client) — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be exactly:  http://localhost:5174/api/zklogin/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5174/api/zklogin/callback

# zkLogin prover. With a Shinami key, Shinami manages the salt + proof:
#   https://app.shinami.com  (zkLogin Wallet + zkProver services)
# Leave SHINAMI_API_KEY blank to use the Mysten dev prover with a locally
# derived salt (testnet only — fine for development).
SHINAMI_API_KEY=
# SALT_SECRET is only used by the dev-prover fallback (HMAC salt). Optional.
SALT_SECRET=
